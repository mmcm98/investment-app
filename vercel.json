{
  "functions": {
    "api/anthropic-proxy.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/market/batch.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/analysis/*.js": {
      "memory": 1024,
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/__proxy_sharesight/:path*",
      "destination": "https://api.sharesight.com/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
