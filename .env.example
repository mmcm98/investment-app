# Copy to `.env` or `.env.local` and fill in values.
# `npm run dev` loads `.env` then `.env.local` (later overrides earlier).

# --- Supabase (cloud) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-side aliases (optional; fall back to VITE_* above)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- AI keys (server proxy reads these; VITE_* fallbacks accepted) ---
ANTHROPIC_API_KEY=
VITE_ANTHROPIC_API_KEY=
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=
FMP_API_KEY=
VITE_FMP_API_KEY=

# --- Sharesight OAuth (client + server) ---
VITE_SHARESIGHT_CLIENT_ID_DEV=
VITE_SHARESIGHT_CLIENT_SECRET_DEV=
VITE_SHARESIGHT_CLIENT_ID_PROD=
VITE_SHARESIGHT_CLIENT_SECRET_PROD=
SHARESIGHT_CLIENT_ID=
SHARESIGHT_CLIENT_SECRET=
VITE_SHARESIGHT_PORTFOLIO_UUID_CORE=
VITE_SHARESIGHT_PORTFOLIO_UUID_SATELLITE=
VITE_SHARESIGHT_OAUTH_REDIRECT_URI=
VITE_PUBLIC_APP_URL=

# --- App ---
VITE_APP_ENV=development

# --- Local API server ---
LOCAL_API_PORT=3001

# --- Optional route secrets (leave blank for local dev) ---
ANALYSIS_API_SECRET=
MARKET_API_SECRET=

# --- Optional model overrides ---
# CLAUDE_ANALYSIS_MODEL=claude-sonnet-4-6
# CLAUDE_BRIEFING_MODEL=claude-sonnet-4-6
# GEMINI_RESEARCH_MODEL=gemini-2.5-flash
# GEMINI_FLASH_MODEL=gemini-2.5-flash
